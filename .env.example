# =============================================================================
# AIRIS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# AI Provider API Keys
# ---------------------------------------------------------------------------
# Set at least one provider API key for AIRIS to function.
# See `airis --help` for the full list of supported providers.

# Google Gemini (default provider)
# GEMINI_AAIRIS_KEY=your-gemini-key

# Anthropic Claude
# ANTHROPIC_AAIRIS_KEY=your-anthropic-key

# OpenAI GPT
# OPENAI_AAIRIS_KEY=your-openai-key

# OpenRouter (multi-provider)
# OPENROUTER_AAIRIS_KEY=your-openrouter-key

# Other providers (see airis --help for full list)
# XAI_AAIRIS_KEY=
# GROQ_AAIRIS_KEY=
# MISTRAL_AAIRIS_KEY=

# ---------------------------------------------------------------------------
# AIRIS Configuration
# ---------------------------------------------------------------------------

# Config directory override (default: ~/.airis/agent)
# AIRIS_CODING_AGENT_DIR=

# Session storage directory override (default: ~/.airis/agent/sessions)
# AIRIS_CODING_AGENT_SESSION_DIR=

# Disable startup network operations (set to 1)
# AIRIS_OFFLINE=0
