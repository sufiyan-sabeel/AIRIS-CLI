# API Keys - Uncomment and set your preferred provider
# Get keys from: https://pi.dev/docs/latest

# Google Gemini (default)
# GEMINI_API_KEY=your-gemini-key

# Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-key

# OpenAI
# OPENAI_API_KEY=your-openai-key

# OpenRouter (multi-provider)
# OPENROUTER_API_KEY=your-openrouter-key

# Other providers (see airis --help for full list)
# XAI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
